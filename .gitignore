# ─────────────────────────────────────────────────────────────
# Purrlington Island — root .gitignore
# ─────────────────────────────────────────────────────────────

# === Secrets / environment (NEVER commit real values — RULES.md) ===
.env
.env.*
*.env
!.env.example
!**/.env.example
.mcp.json
!.mcp.json.example
application-local.yaml
application-local.yml
*.pem
*.key
secrets.*

# === Local-only: Claude tooling & internal AI context docs ===
# (kept local — not uploaded to the repo / cloud). Anchored to repo root.
/.claude/
/docs/

# === Node / TypeScript (frontend, hotel, broadcast) ===
node_modules/
dist/
build/
.next/
out/
coverage/
*.tsbuildinfo
.pnpm-store/
.npm/
npm-debug.log*
pnpm-debug.log*
yarn-error.log*

# === Python (airport, parrot) ===
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
instance/

# === Go (gateway) ===
/gateway/gateway
/gateway/gateway.exe
*.exe
*.out

# === Kotlin / Gradle / Java (beach) ===
.gradle/
.kotlin/
*.class
fat.jar
*.jar
!**/gradle/wrapper/gradle-wrapper.jar
*.war
*.ear
target/
hs_err_pid*
replay_pid*

# === Prisma (hotel) ===
generated/

# === Databases / dumps (airport SQLite, local PG dumps) ===
*.db
*.sqlite
*.sqlite3
*.mv.db
*.trace.db
*.h2.db
*.dump

# === Logs / reports / coverage ===
logs/
*.log
test-results/
reports/
jacoco.exec
tmp/

# === IDE / OS ===
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db
